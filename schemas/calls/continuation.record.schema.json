{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-shop.local/schemas/calls/continuation.record.schema.json",
  "title": "Garage continuation.record Call",
  "allOf": [
    {
      "$ref": "../common/call-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "call_type": {
          "const": "continuation.record"
        },
        "from_role": {
          "const": "jarvis"
        },
        "to_role": {
          "const": "alfred"
        },
        "reported_status": false,
        "attempt_no": false
      },
      "required": ["schema_version", "call_type", "task_id", "from_role", "to_role"],
      "anyOf": [
        {
          "required": ["payload"],
          "properties": {
            "payload": {
              "type": "object",
              "minProperties": 1
            }
          }
        },
        {
          "required": ["payload_ref"]
        }
      ]
    }
  ],
  "unevaluatedProperties": false
}
