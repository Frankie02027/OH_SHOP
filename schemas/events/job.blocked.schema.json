{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-shop.local/schemas/events/job.blocked.schema.json",
  "title": "Garage job.blocked Event",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_type": {
      "const": "job.blocked"
    },
    "event_id": {
      "$ref": "../common/id-types.schema.json#/$defs/event_id"
    },
    "task_id": {
      "$ref": "../common/id-types.schema.json#/$defs/task_id"
    },
    "job_id": {
      "$ref": "../common/id-types.schema.json#/$defs/job_id"
    },
    "related_call_type": {
      "const": "failure.report"
    },
    "reported_status": {
      "const": "blocked"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "../objects/artifact-ref.schema.json"
      }
    },
    "workspace_refs": {
      "type": "array",
      "items": {
        "$ref": "../objects/workspace-ref.schema.json"
      }
    },
    "payload_ref": {
      "$ref": "../objects/payload-ref.schema.json"
    }
  },
  "required": [
    "schema_version",
    "event_type",
    "event_id",
    "task_id",
    "job_id",
    "related_call_type",
    "reported_status",
    "recorded_at"
  ],
  "additionalProperties": false
}
