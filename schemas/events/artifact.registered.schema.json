{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-shop.local/schemas/events/artifact.registered.schema.json",
  "title": "Garage artifact.registered Event",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_type": {
      "const": "artifact.registered"
    },
    "event_id": {
      "$ref": "../common/id-types.schema.json#/$defs/event_id"
    },
    "task_id": {
      "$ref": "../common/id-types.schema.json#/$defs/task_id"
    },
    "job_id": {
      "$ref": "../common/id-types.schema.json#/$defs/job_id"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "../objects/artifact-ref.schema.json"
      },
      "minItems": 1
    }
  },
  "required": ["schema_version", "event_type", "event_id", "task_id", "recorded_at", "artifact_refs"],
  "additionalProperties": false
}
