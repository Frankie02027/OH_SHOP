{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-shop.local/schemas/events/job.created.schema.json",
  "title": "Garage job.created Event",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_type": {
      "const": "job.created"
    },
    "event_id": {
      "$ref": "../common/id-types.schema.json#/$defs/event_id"
    },
    "task_id": {
      "$ref": "../common/id-types.schema.json#/$defs/task_id"
    },
    "job_id": {
      "$ref": "../common/id-types.schema.json#/$defs/job_id"
    },
    "parent_job_id": {
      "type": ["string", "null"],
      "pattern": "^T[0-9]{6}\\.J[0-9]{3}$"
    },
    "from_role": {
      "$ref": "../common/roles.schema.json"
    },
    "to_role": {
      "$ref": "../common/roles.schema.json"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["schema_version", "event_type", "event_id", "task_id", "job_id", "recorded_at"],
  "additionalProperties": false
}
