{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-shop.local/schemas/objects/task-record.schema.json",
  "title": "Garage Task Record",
  "type": "object",
  "properties": {
    "task_id": {
      "$ref": "../common/id-types.schema.json#/$defs/task_id"
    },
    "task_state": {
      "$ref": "../common/task-states.schema.json"
    },
    "current_plan_version": {
      "$ref": "../common/id-types.schema.json#/$defs/plan_version"
    },
    "current_job_id": {
      "$ref": "../common/id-types.schema.json#/$defs/job_id"
    },
    "latest_checkpoint_id": {
      "$ref": "../common/id-types.schema.json#/$defs/checkpoint_id"
    },
    "latest_continuation_ref": {
      "$ref": "./content-ref.schema.json"
    },
    "summary_ref": {
      "$ref": "./content-ref.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["task_id", "task_state", "created_at"],
  "additionalProperties": false
}
