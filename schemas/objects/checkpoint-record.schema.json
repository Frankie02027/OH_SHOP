{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-shop.local/schemas/objects/checkpoint-record.schema.json",
  "title": "Garage Checkpoint Record",
  "type": "object",
  "properties": {
    "checkpoint_id": {
      "$ref": "../common/id-types.schema.json#/$defs/checkpoint_id"
    },
    "task_id": {
      "$ref": "../common/id-types.schema.json#/$defs/task_id"
    },
    "job_id": {
      "$ref": "../common/id-types.schema.json#/$defs/job_id"
    },
    "plan_version": {
      "$ref": "../common/id-types.schema.json#/$defs/plan_version"
    },
    "current_active_item": {
      "$ref": "../common/id-types.schema.json#/$defs/item_id"
    },
    "key_ref_bundle": {
      "type": "object",
      "properties": {
        "artifact_refs": {
          "type": "array",
          "items": {
            "$ref": "./artifact-ref.schema.json"
          }
        },
        "workspace_refs": {
          "type": "array",
          "items": {
            "$ref": "./workspace-ref.schema.json"
          }
        },
        "payload_ref": {
          "$ref": "./payload-ref.schema.json"
        },
        "content_ref": {
          "$ref": "./content-ref.schema.json"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "reason": {
      "type": "string"
    },
    "resume_point": {
      "type": ["object", "string"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["checkpoint_id", "task_id", "created_at"],
  "additionalProperties": false
}
