{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-shop.local/schemas/objects/artifact-index-record.schema.json",
  "title": "Garage Artifact Index Record",
  "type": "object",
  "properties": {
    "artifact_id": {
      "$ref": "../common/id-types.schema.json#/$defs/artifact_id"
    },
    "task_id": {
      "$ref": "../common/id-types.schema.json#/$defs/task_id"
    },
    "job_id": {
      "$ref": "../common/id-types.schema.json#/$defs/job_id"
    },
    "event_id": {
      "$ref": "../common/id-types.schema.json#/$defs/event_id"
    },
    "kind": {
      "$ref": "../common/artifact-kinds.schema.json"
    },
    "workspace_ref": {
      "anyOf": [
        {
          "$ref": "./workspace-ref.schema.json"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "reported_by": {
      "$ref": "../common/roles.schema.json"
    },
    "payload_ref": {
      "$ref": "./payload-ref.schema.json"
    },
    "description": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "mime_type": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "hash": {
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "kind",
    "workspace_ref",
    "reported_by",
    "created_at"
  ],
  "additionalProperties": false
}
