# stagehand-mcp environment variables
# Copy to .env and edit as needed:  cp .env.example .env

# ── Model / LLM ───────────────────────────────────────────────
# Model name (must match a loaded model in LM Studio/Ollama)
STAGEHAND_MODEL=mistralai/devstral-small-2-2512

# LM Studio API endpoint
STAGEHAND_LLM_BASE_URL=http://host.docker.internal:1234/v1
STAGEHAND_LLM_API_KEY=lm-studio

# ── Browser ───────────────────────────────────────────────────
# Chromium executable path
CHROME_PATH=/usr/bin/chromium
# Run headless (true/false)
HEADLESS=true
# Browser viewport dimensions
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080
# Open DevTools panel (true/false)
DEVTOOLS=false

# ── Server ────────────────────────────────────────────────────
# Host to bind (0.0.0.0 for all interfaces)
MCP_HOST=0.0.0.0
# Port for MCP SHTTP endpoint
MCP_PORT=3020

# ── Features ──────────────────────────────────────────────────
# Enable experimental features like agent custom tools
EXPERIMENTAL=true

NODE_ENV=production
